---
export const prerender = false;
import Base from "../layouts/Base.astro";
---
<Base title="Privacy Policy | Harmony Threads" description="Privacy policy — how we collect, use, and protect your data." noindex={true}>
  <article class="pt-32 pb-24 max-w-3xl mx-auto px-6">
    <h1 class="font-['Fraunces'] font-medium text-4xl mb-10" style="color:#f0ece3;">Privacy Policy</h1>
    <div class="space-y-6 text-sm leading-relaxed" style="color:#a09a93;">
      <p>Effective date: April 20, 2026</p>
      <section><h2 class="font-['Fraunces'] font-medium text-xl mb-2" style="color:#f0ece3;">What we collect</h2><p>When you place an order, we collect your name, email address, and shipping address. Newsletter subscribers: email only. We use cookies only for essential site functionality.</p></section>
      <section><h2 class="font-['Fraunces'] font-medium text-xl mb-2" style="color:#f0ece3;">How we use it</h2><p>Order data is used to fulfil your purchase. Email is used for transactional messages and, if opted in, our newsletter. We never sell your data.</p></section>
      <section><h2 class="font-['Fraunces'] font-medium text-xl mb-2" style="color:#f0ece3;">Third parties</h2><p>Payments via Stripe. Email via Resend. Database on Supabase. We do not store card details.</p></section>
      <section><h2 class="font-['Fraunces'] font-medium text-xl mb-2" style="color:#f0ece3;">Your rights</h2><p>Request deletion of your data via the <a href="/contact" class="underline hover:text-[#c0392b] transition-colors" style="color:#f0ece3;">contact form</a>.</p></section>
    </div>
  </article>
</Base>
