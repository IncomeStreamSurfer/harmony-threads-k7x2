---
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { stripe } from "../../lib/stripe";
const sessionId = Astro.url.searchParams.get("session_id");
let session: any = null;
if (sessionId) { try { session = await stripe().checkout.sessions.retrieve(sessionId); } catch {} }
---
<Base title="Order Confirmed | Harmony Threads" description="Your order has been confirmed." noindex={true}>
  <div class="pt-32 pb-24 max-w-2xl mx-auto px-6 text-center">
    <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-8" style="background:rgba(192,57,43,0.1);"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22,4 12,14.01 9,11.01"/></svg></div>
    <h1 class="font-['Fraunces'] font-medium text-4xl mb-4" style="color:#f0ece3;">Order confirmed</h1>
    {session ? (<div><p class="text-lg mb-2" style="color:#a09a93;">Thanks, {session.customer_details?.name ?? "friend"}!</p><p class="mb-8" style="color:#a09a93;">Total: <strong style="color:#f0ece3;">{(session.currency??'usd').toUpperCase()} {((session.amount_total??0)/100).toFixed(2)}</strong></p></div>) : (<p class="text-lg mb-8" style="color:#a09a93;">Your payment went through. Confirmation email on the way.</p>)}
    <p class="text-sm mb-10" style="color:#5a5a5a;">Digital downloads via email within minutes. Physical orders ship within 2–3 business days.</p>
    <div class="flex justify-center gap-4">
      <a href="/shop" class="inline-flex items-center gap-2 px-6 py-3 font-semibold text-sm hover:-translate-y-0.5 transition-all" style="background:#c0392b;color:#fff;border-radius:6px;">Keep shopping</a>
      <a href="/" class="inline-flex items-center px-6 py-3 font-semibold text-sm transition-colors hover:text-[#f0ece3]" style="color:#a09a93;border:1px solid rgba(240,236,227,0.15);border-radius:6px;">Home</a>
    </div>
  </div>
</Base>
