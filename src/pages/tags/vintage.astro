---
export const prerender = false;
import Base from "../../layouts/Base.astro";
const products = [{ slug: 'physical-product-the-band-t-shirt', name: '"The Band" Graphic T-Shirt', price: '19.99', compareAt: '24.99', desc: 'Timeless design for an iconic band. Vintage-style graphics on premium cotton.', image: 'https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=1000' }];
const collectionSchema = { "@context": "https://schema.org", "@type": "CollectionPage", "name": "Vintage Style Rock Music Products", "url": `${Astro.site ?? ""}tags/vintage` };
---
<Base title="Vintage Style Rock Music Apparel | Harmony Threads" description="Timeless cuts, classic graphics. Our vintage-tagged collection brings rock aesthetics into modern everyday wear." structuredData={collectionSchema}>
  <div class="pt-32 pb-24 max-w-7xl mx-auto px-6">
    <nav class="mb-10 text-sm flex items-center gap-2" style="color:#5a5a5a;"><a href="/" class="hover:text-[#f0ece3] transition-colors">Home</a><span>/</span><a href="/shop" class="hover:text-[#f0ece3] transition-colors">Shop</a><span>/</span><span style="color:#a09a93;">Vintage Style</span></nav>
    <div class="max-w-3xl mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] mb-3 accent-dot" style="color:#c0392b;">Tag</p>
      <h1 class="font-['Fraunces'] font-medium mb-4" style="font-size:clamp(40px,6vw,64px);line-height:1.0;color:#f0ece3;">Vintage Style</h1>
      <p class="text-lg leading-relaxed mb-6" style="color:#a09a93;">Not vintage. Vintage-inspired. Our pieces carry the aesthetic weight of 1970s rock without the mystery stains. Every design takes cues from concert shirts, record sleeves, and the hand-set typography of an era when design was done by craftspeople.</p>
      <p class="leading-relaxed" style="color:#a09a93;">Start with the <a href="/products/physical-product-the-band-t-shirt" class="underline hover:text-[#c0392b] transition-colors" style="color:#f0ece3;">"The Band" Graphic T-Shirt</a>. Pair it with <a href="/collections/digital" class="underline hover:text-[#c0392b] transition-colors" style="color:#f0ece3;">The History of Rock Music</a> to know the full story.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {products.map(p => (<article class="group"><a href={`/products/${p.slug}`} class="block"><div class="relative overflow-hidden mb-4" style="border-radius:4px;aspect-ratio:4/5;background:#171419;"><img src={p.image} alt={p.name + ' — vintage rock music apparel'} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /><span class="absolute top-3 left-3 text-[10px] font-bold uppercase tracking-widest px-2 py-1" style="background:#c0392b;color:#fff;border-radius:3px;">Vintage Style</span></div><h2 class="font-['Fraunces'] font-medium text-xl mb-1 group-hover:text-[#c0392b] transition-colors" style="color:#f0ece3;">{p.name}</h2><p class="text-sm mb-3" style="color:#a09a93;">{p.desc}</p><div class="flex items-center gap-3"><span class="font-semibold" style="color:#f0ece3;">${p.price}</span><span class="text-sm line-through" style="color:#5a5a5a;">${p.compareAt}</span></div></a></article>))}
    </div>
    <div class="mt-16 pt-10 flex gap-4" style="border-top:1px solid rgba(240,236,227,0.08);"><a href="/collections/apparel" class="text-sm font-medium transition-colors hover:text-[#f0ece3]" style="color:#a09a93;">→ All apparel</a><a href="/tags/rock-music" class="text-sm font-medium transition-colors hover:text-[#f0ece3]" style="color:#a09a93;">→ Rock music</a><a href="/shop" class="text-sm font-medium transition-colors hover:text-[#f0ece3]" style="color:#a09a93;">→ All products</a></div>
  </div>
</Base>
