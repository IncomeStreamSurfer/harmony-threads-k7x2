---
export const prerender = false;
import Base from "../layouts/Base.astro";
---
<Base title="Shipping & Returns | Harmony Threads" description="Free shipping over $75. 30-day returns on physical products. Digital downloads delivered instantly.">
  <article class="pt-32 pb-24 max-w-3xl mx-auto px-6">
    <h1 class="font-['Fraunces'] font-medium text-4xl mb-10" style="color:#f0ece3;">Shipping & Returns</h1>
    <div class="space-y-8" style="color:#a09a93;">
      <section><h2 class="font-['Fraunces'] font-medium text-2xl mb-3" style="color:#f0ece3;">Shipping</h2><p class="leading-relaxed mb-3">Standard US shipping 3–5 business days. International shipping available. Free on orders over $75.</p></section>
      <section><h2 class="font-['Fraunces'] font-medium text-2xl mb-3" style="color:#f0ece3;">Digital Downloads</h2><p class="leading-relaxed">Delivered instantly via email after payment. If not received within 10 minutes, <a href="/contact" class="underline hover:text-[#c0392b] transition-colors" style="color:#f0ece3;">contact us</a>.</p></section>
      <section><h2 class="font-['Fraunces'] font-medium text-2xl mb-3" style="color:#f0ece3;">Returns</h2><p class="leading-relaxed mb-3">Physical products: 30-day return window, unworn, original condition. Digital: non-refundable. To start a return, <a href="/contact" class="underline hover:text-[#c0392b] transition-colors" style="color:#f0ece3;">get in touch</a>.</p></section>
    </div>
  </article>
</Base>
