---
export const prerender = false;
import Base from "../layouts/Base.astro";
import { anonClient } from "../lib/supabase";

const sb = anonClient();
let products: any[] = [];
if (sb) {
  const { data } = await sb
    .from("products")
    .select("id, slug, name, description, price_pence, compare_at_pence, currency, image_url, tags")
    .not("published_at", "is", null)
    .order("created_at", { ascending: true });
  products = data ?? [];
}

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "All Products — Harmony Threads",
  "url": `${Astro.site ?? ""}shop`,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${Astro.site ?? ""}products/${p.slug}`,
      "name": p.name,
    })),
  },
};
---

<Base
  title="Shop Rock Music Apparel & Digital Downloads | Harmony Threads"
  description="Browse Harmony Threads' full catalogue — The Band graphic t-shirts, rock history eBooks, and premium accessories. Free shipping over $75."
  structuredData={collectionSchema}
>
  <div class="pt-32 pb-24 max-w-7xl mx-auto px-6">
    <div class="mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] mb-3 accent-dot" style="color:#c0392b;">The catalogue</p>
      <h1 class="font-['Fraunces'] font-medium mb-4" style="font-size:clamp(40px,6vw,72px);line-height:1.0;color:#f0ece3;">All Products</h1>
      <p class="text-lg max-w-lg leading-relaxed" style="color:#a09a93;">
        Rock music culture, worn and read. Every piece we make — graphic tees, digital books, and more.
        Explore our <a href="/collections/apparel" class="underline hover:text-[#c0392b] transition-colors">apparel collection</a> or
        <a href="/collections/digital" class="underline hover:text-[#c0392b] transition-colors">digital downloads</a>.
      </p>
    </div>

    {products.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((p) => {
          const price = (p.price_pence / 100).toFixed(2);
          const compareAt = p.compare_at_pence ? (p.compare_at_pence / 100).toFixed(2) : null;
          const isDigital = p.tags?.includes('eBook') || p.tags?.includes('Digital');
          return (
            <article class="group">
              <a href={`/products/${p.slug}`} class="block">
                <div class="relative overflow-hidden mb-4" style="border-radius:4px;aspect-ratio:4/5;background:#171419;">
                  <img src={p.image_url || 'https://picsum.photos/seed/' + p.slug + '/800/1000'} alt={p.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                  {isDigital && <span class="absolute top-3 left-3 text-[10px] font-bold uppercase tracking-widest px-2 py-1" style="background:rgba(13,11,15,0.9);color:#c0392b;border:1px solid rgba(192,57,43,0.4);border-radius:3px;">Digital</span>}
                </div>
                <h2 class="font-['Fraunces'] font-medium text-xl mb-1 transition-colors group-hover:text-[#c0392b]" style="color:#f0ece3;">{p.name}</h2>
                <p class="text-sm mb-3 leading-relaxed" style="color:#a09a93;">{p.description?.slice(0, 120)}</p>
                <div class="flex items-center gap-3">
                  <span class="font-semibold" style="color:#f0ece3;">${price}</span>
                  {compareAt && <span class="text-sm line-through" style="color:#5a5a5a;">${compareAt}</span>}
                </div>
              </a>
            </article>
          );
        })}
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <article class="group"><a href="/products/physical-product-the-band-t-shirt" class="block"><div class="relative overflow-hidden mb-4" style="border-radius:4px;aspect-ratio:4/5;background:#171419;"><img src="https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=1000" alt="The Band T-Shirt" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /><span class="absolute top-3 left-3 text-[10px] font-bold uppercase tracking-widest px-2 py-1" style="background:#c0392b;color:#fff;border-radius:3px;">Top Seller</span></div><h2 class="font-['Fraunces'] font-medium text-xl mb-1 transition-colors group-hover:text-[#c0392b]" style="color:#f0ece3;">"The Band" Graphic T-Shirt</h2><p class="text-sm mb-3" style="color:#a09a93;">Celebrate the timeless legacy of one of rock's most influential groups.</p><div class="flex items-center gap-3"><span class="font-semibold" style="color:#f0ece3;">$19.99</span><span class="text-sm line-through" style="color:#5a5a5a;">$24.99</span></div></a></article>
        <article class="group"><a href="/products/digital-product-the-history-of-rock-music" class="block"><div class="relative overflow-hidden mb-4" style="border-radius:4px;aspect-ratio:4/5;background:#171419;"><img src="https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=1000" alt="The History of Rock Music" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /><span class="absolute top-3 left-3 text-[10px] font-bold uppercase tracking-widest px-2 py-1" style="background:rgba(13,11,15,0.9);color:#c0392b;border:1px solid rgba(192,57,43,0.4);border-radius:3px;">Digital</span></div><h2 class="font-['Fraunces'] font-medium text-xl mb-1 transition-colors group-hover:text-[#c0392b]" style="color:#f0ece3;">The History of Rock Music</h2><p class="text-sm mb-3" style="color:#a09a93;">From roots to revolution — the definitive digital guide.</p><span class="font-semibold" style="color:#f0ece3;">From $9.99</span></a></article>
        <article class="group"><a href="/products/example-perfume" class="block"><div class="relative overflow-hidden mb-4" style="border-radius:4px;aspect-ratio:4/5;background:#171419;"><img src="https://burst.shopifycdn.com/photos/black-glass-perfume-bottle-and-spritzer.jpg?width=500" alt="Example Perfume" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /><span class="absolute top-3 left-3 text-[10px] font-bold uppercase tracking-widest px-2 py-1" style="background:#c0392b;color:#fff;border-radius:3px;">Premium</span></div><h2 class="font-['Fraunces'] font-medium text-xl mb-1 transition-colors group-hover:text-[#c0392b]" style="color:#f0ece3;">Example Perfume</h2><p class="text-sm mb-3" style="color:#a09a93;">Premium fragrance for the discerning music lover.</p><span class="font-semibold" style="color:#f0ece3;">$74.99</span></a></article>
      </div>
    )}
  </div>
</Base>
