---
const links = [
  { href: '/shop', label: 'Shop' },
  { href: '/collections/apparel', label: 'Apparel' },
  { href: '/collections/digital', label: 'Digital' },
  { href: '/about', label: 'Our Story' },
  { href: '/contact', label: 'Contact' },
];
const path = Astro.url.pathname;
---
<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="w-7 h-7 rounded-full flex items-center justify-center" style="background: #c0392b;"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1 L13 7 L7 13 L1 7 Z" stroke="#f0ece3" stroke-width="1.5" fill="none"/></svg></span>
      <span class="font-['Fraunces'] font-medium text-lg tracking-tight" style="color:#f0ece3;">Harmony Threads</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {links.map(l => (<a href={l.href} class={`text-sm font-medium transition-colors duration-200 ${path === l.href || path.startsWith(l.href + '/') ? 'text-[#c0392b]' : 'text-[#a09a93] hover:text-[#f0ece3]'}`}>{l.label}</a>))}
    </nav>
    <div class="flex items-center gap-4">
      <button id="cart-toggle" class="relative p-2 text-[#a09a93] hover:text-[#f0ece3] transition-colors" aria-label="Open cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span id="cart-count" class="absolute -top-1 -right-1 w-4 h-4 rounded-full text-[10px] font-bold flex items-center justify-center hidden" style="background:#c0392b;color:#fff;">0</span>
      </button>
      <button id="mobile-menu-btn" class="md:hidden p-2 text-[#a09a93] hover:text-[#f0ece3]" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t" style="border-color:rgba(240,236,227,0.1);background:#0d0b0f;">
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map(l => (<a href={l.href} class="text-sm font-medium text-[#a09a93] hover:text-[#f0ece3] transition-colors">{l.label}</a>))}
    </div>
  </div>
</header>
<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => { header?.classList.toggle('scrolled', window.scrollY > 60); });
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => { document.getElementById('mobile-menu')?.classList.toggle('hidden'); });
  function updateCartCount() {
    try {
      const cart = JSON.parse(localStorage.getItem('ht_cart') || '[]');
      const total = cart.reduce((sum, item) => sum + (item.qty || 0), 0);
      const badge = document.getElementById('cart-count');
      if (badge) { badge.textContent = String(total); badge.classList.toggle('hidden', total === 0); }
    } catch {}
  }
  updateCartCount();
  window.addEventListener('storage', updateCartCount);
  window.addEventListener('cart-updated', updateCartCount);
</script>
<style>
  #site-header.scrolled { background: rgba(13,11,15,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(240,236,227,0.08); }
</style>
