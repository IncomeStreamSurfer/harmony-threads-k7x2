---
const year = 2026;
---
<footer style="border-top:1px solid rgba(240,236,227,0.1);background:#0d0b0f;" class="mt-24">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4"><span class="w-6 h-6 rounded-full flex items-center justify-center" style="background:#c0392b;"><svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M7 1 L13 7 L7 13 L1 7 Z" stroke="#f0ece3" stroke-width="1.5" fill="none"/></svg></span><span class="font-['Fraunces'] font-medium" style="color:#f0ece3;">Harmony Threads</span></a>
        <p class="text-sm leading-relaxed max-w-xs" style="color:#a09a93;">Rock music culture, worn and read. Graphic tees, digital books, and artefacts for the music-obsessed.</p>
        <p class="text-xs mt-6" style="color:#5a5a5a;">© {year} Harmony Threads. All rights reserved.</p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:#5a5a5a;">Shop</p>
        <ul class="flex flex-col gap-2">
          <li><a href="/shop" class="text-sm hover:text-[#f0ece3] transition-colors" style="color:#a09a93;">All Products</a></li>
          <li><a href="/collections/apparel" class="text-sm hover:text-[#f0ece3] transition-colors" style="color:#a09a93;">Apparel</a></li>
          <li><a href="/collections/digital" class="text-sm hover:text-[#f0ece3] transition-colors" style="color:#a09a93;">Digital Downloads</a></li>
          <li><a href="/tags/vintage" class="text-sm hover:text-[#f0ece3] transition-colors" style="color:#a09a93;">Vintage Style</a></li>
        </ul>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:#5a5a5a;">Company</p>
        <ul class="flex flex-col gap-2">
          <li><a href="/about" class="text-sm hover:text-[#f0ece3] transition-colors" style="color:#a09a93;">Our Story</a></li>
          <li><a href="/contact" class="text-sm hover:text-[#f0ece3] transition-colors" style="color:#a09a93;">Contact</a></li>
          <li><a href="/blog" class="text-sm hover:text-[#f0ece3] transition-colors" style="color:#a09a93;">Journal</a></li>
          <li><a href="/shipping" class="text-sm hover:text-[#f0ece3] transition-colors" style="color:#a09a93;">Shipping & Returns</a></li>
          <li><a href="/privacy" class="text-sm hover:text-[#f0ece3] transition-colors" style="color:#a09a93;">Privacy Policy</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>
